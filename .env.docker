# ============================================
# Variaveis de Ambiente - WosKaraoke DOCKER
# ============================================

# Banco de Dados (usado pelo docker-compose)
DB_NAME=woskaraoke
DB_USER=karaoke_user
DB_PASS=karaoke_pass

# Google OAuth (substitua pelos seus valores)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pusher (Real-time) (substitua pelos seus valores)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=sa1

# App
APP_DEBUG=true
APP_ENV=development
