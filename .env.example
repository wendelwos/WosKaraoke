# Variáveis de Ambiente - WosKaraoke
# Copie este arquivo para .env e configure seus valores

# ============================================
# BANCO DE DADOS
# ============================================
DB_TYPE=mysql
DB_HOST=localhost
DB_NAME=woskaraoke
DB_USER=root
DB_PASS=

# ============================================
# AUTENTICAÇÃO GOOGLE
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================
# PUSHER (Real-time)
# ============================================
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=sa1

# ============================================
# CONFIGURAÇÕES DO APP
# ============================================
APP_DEBUG=false
APP_ENV=production
